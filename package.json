{
  "name": "florines-place",
  "version": "0.1.0",
  "private": true,
  "description": "A shared family cabin app for Florine's Place on Hood Canal.",
  "scripts": {
    "dev": "npm run dev:demo",
    "dev:demo": "NEXT_PUBLIC_APP_MODE=demo next dev",
    "dev:live": "NEXT_PUBLIC_APP_MODE=live next dev",
    "build": "npm run build:live",
    "build:demo": "NEXT_PUBLIC_APP_MODE=demo next build",
    "build:live": "NEXT_PUBLIC_APP_MODE=live next build",
    "start": "npm run start:live",
    "start:demo": "NEXT_PUBLIC_APP_MODE=demo next start",
    "start:live": "NEXT_PUBLIC_APP_MODE=live next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.7",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.10",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.0"
  }
}
