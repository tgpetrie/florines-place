# Private directions (required). Keep real values in .env.local or your host's
# encrypted environment settings; never commit them.
CABIN_PRIVATE_ADDRESS=""
CABIN_DIRECTIONS_PASSCODE=""
CABIN_WIFI_NAME=""
CABIN_WIFI_PASSWORD=""
CABIN_DOOR_CODE=""
DIRECTIONS_APPROVER_TOM=""
DIRECTIONS_APPROVER_KATE=""
DIRECTIONS_APPROVER_PEGGY=""
DIRECTIONS_APPROVER_GREG=""

# Optional: when both are configured, approval requests are sent directly.
# Without them, the app opens a pre-addressed email draft for the requester.
RESEND_API_KEY=""
DIRECTIONS_REQUEST_FROM="Florine's Place <directions@your-domain.example>"

# Build mode. Production defaults to live if this is missing. Demo must opt in
# explicitly and keeps writable browser-local seed data.
NEXT_PUBLIC_APP_MODE="live"
NEXT_PUBLIC_DEMO_START_MONTH="2026-07"

# Live reservation database — server-only. Use a modern Supabase secret key,
# never a NEXT_PUBLIC variable or browser bundle.
SUPABASE_URL=""
SUPABASE_SECRET_KEY=""

# Supabase Auth — safe for the browser when paired with RLS. Use the project
# URL and modern publishable key (sb_publishable_...), never a secret key.
# Best practice: set both public values even if server-side auth can fall back
# to SUPABASE_URL while you finish wiring the project.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Live local conditions — free feeds. These default to the current Hansville /
# Hood Canal values in code if omitted, but set them explicitly for the real
# cabin once you know the exact coordinates and tide station.
CABIN_LATITUDE=""
CABIN_LONGITUDE=""
NOAA_TIDE_STATION_ID=""
